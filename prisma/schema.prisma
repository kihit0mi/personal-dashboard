generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      String   @default("ADMIN")

  createdAt DateTime @default(now())
}

enum PersonGroup {
  WORK
  FAMILY
  EX_WIFE
  FRIEND
  CHILD
}

model Person {
  id        Int         @id @default(autoincrement())
  name      String
  colorCode String      @default("#CCCCCC") 
  group     PersonGroup @default(FRIEND)

  tasks     Task[]   
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Recurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

model Task {
  id            Int         @id @default(autoincrement())
  name          String
  status        String      @default("PENDING")
  description   String?
  
  startDate     DateTime
  endDate       DateTime?
  
  recurrence    Recurrence  @default(NONE)
  recurringDays DayOfWeek[]
  
  people        Person[] 
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model CustodyDay {
  date      String   @id // yyyy-mm-dd
  status    String   // with-children or without-children
  updatedAt DateTime @updatedAt

  @@map("custody_days")
}

model CalendarEvent {
  id              String   @id @default(cuid())
  date            String
  title           String
  type            String
  requiresPacking Boolean  @default(false)
  packingNotes    String?
  pickupNotes     String?
  createdAt       DateTime @default(now())

  @@index([date])
}